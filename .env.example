# ── Veritabanı (Supabase PostgreSQL — Prisma) ─────────────────────────────
# Lokal dev: Session pooler (5432) kullanılabilir.
# Vercel production: Transaction pooler (6543) + pgbouncer=true ZORUNLU.
# Şifrede @ # / ? gibi karakterler varsa URL encode edin (@ → %40).
#
# Lokal:
# DATABASE_URL="postgresql://postgres.[REF]:[PASS]@...pooler.supabase.com:5432/postgres?sslmode=require"
# Vercel:
# DATABASE_URL="postgresql://postgres.[REF]:[PASS]@...pooler.supabase.com:6543/postgres?pgbouncer=true&connection_limit=1"
DATABASE_URL="postgresql://postgres.[PROJECT_REF]:[PASSWORD]@aws-0-[REGION].pooler.supabase.com:5432/postgres?sslmode=require"

# ── Clerk (Kimlik doğrulama) ───────────────────────────────────────────────
# Lokal (.env.local): pk_test_ / sk_test_ (Development instance)
# Canlı (.env.production.local + Vercel): pk_live_ / sk_live_ (Production)
NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY=
CLERK_SECRET_KEY=
NEXT_PUBLIC_CLERK_SIGN_IN_URL=/sign-in
NEXT_PUBLIC_CLERK_SIGN_UP_URL=/sign-up
NEXT_PUBLIC_CLERK_AFTER_SIGN_IN_URL=/dashboard
NEXT_PUBLIC_CLERK_AFTER_SIGN_UP_URL=/dashboard
# Clerk Dashboard → Webhooks → Endpoint: https://YOUR_DOMAIN/api/webhooks/clerk
# Events: user.created, user.updated, session.created
CLERK_WEBHOOK_SIGNING_SECRET=

# ── Supabase (Sesli CRM — voice_crm_logs tablosu) ─────────────────────────
# Tablo yoksa: npm run db:setup-voice-crm
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=

# ── Yapay zeka API anahtarları ────────────────────────────────────────────
OPENAI_API_KEY=
GEMINI_API_KEY=
GROQ_API_KEY=
# ParselCopilot: Groq llama-3.3-70b-versatile (ücretsiz katman — console.groq.com)

# ── Harita (İstihbarat Radarı — Mapbox) ───────────────────────────────────
NEXT_PUBLIC_MAPBOX_TOKEN=

# ── Yetki belgesi (TTBS — geliştirme bypass) ──────────────────────────────
# Üretimde kullanmayın; CAPTCHA nedeniyle otomatik TTBS doğrulaması yoktur.
# TTBS_DEV_AUTO_VERIFY=1

# ── Iyzico Abonelik (Subscription API) ────────────────────────────────────
# Sandbox: https://sandbox-api.iyzipay.com · Prod: https://api.iyzipay.com
IYZICO_API_KEY=
IYZICO_SECRET_KEY=
IYZICO_BASE_URL=https://sandbox-api.iyzipay.com
# Iyzico panelinde oluşturduğunuz pricing plan reference kodları
IYZICO_PRO_PLAN_REFERENCE=
IYZICO_PREMIUM_PLAN_REFERENCE=
# Webhook URL: https://YOUR_DOMAIN/api/webhooks/iyzico

# ── Super Admin (komuta merkezi ek parola) ────────────────────────────────
# Zorunlu: Clerk oturumu + bu parola. Tanımlı değilse /admin/access girişi kapalıdır.
# Vercel production'da mutlaka güçlü bir değer tanımlayın (hardcoded parola yok).
ADMIN_ACCESS_PASSWORD=
# İsteğe bağlı oturum imzası; yoksa CLERK_SECRET_KEY kullanılır (dev fallback ayrı).
# ADMIN_SESSION_SECRET=

NODE_ENV=development

# --- FSBO Lokal (geliştirme) — Hostinger'e taşınınca production değerleri yazın ---
BOT_SECRET_KEY=parselos-local-dev-bot-secret-2026
CRON_SECRET=parselos-local-dev-cron-secret-2026
NEXT_PUBLIC_APP_URL=http://localhost:3000

# ── Vercel (production — parselos.com) ────────────────────────────────────
# Detaylı adımlar: docs/DEPLOY-VERCEL.md
# NEXT_PUBLIC_APP_URL=https://parselos.com
# Clerk Live keys (pk_live_ / sk_live_) + parselos.com domain Clerk'te tanımlı olmalı
# Webhook: https://parselos.com/api/webhooks/clerk

# Hostinger (yedek VPS): npm run build:hostinger → server.js + PM2

# --- FSBO Scraper (ScraperAPI — artık kullanılmıyor, scraper-bot tercih edilir) ---
# SCRAPER_API_KEY=

# Zor siteler için JS render (daha yavaş, daha fazla kredi)
# FSBO_SCRAPER_RENDER=true

# Opsiyonel: özel arama URL'leri (JSON dizi)
# FSBO_SYNC_SEARCH_URLS=[{"region":"Gölcük","il":"Kocaeli","ilce":"Gölcük","source":"sahibinden","islemTipi":"SATILIK","kategori":"KONUT","searchUrl":"https://www.sahibinden.com/satilik/konut/kocaeli-golcuk"}]

# --- FSBO Opportunity Hunter (local cron worker) ---
FSBO_CONFIG_PATH=scripts/fsbo-watchlist.json
FSBO_STALE_DAYS=60
FSBO_MIN_DELAY_MS=4500
FSBO_MAX_DELAY_MS=11000
FSBO_MAX_SEARCH_RESULTS=25
FSBO_REQUEST_TIMEOUT_MS=30000
FSBO_USER_AGENT="Mozilla/5.0 (Windows NT 10.0; Win64; x64) AppleWebKit/537.36 (KHTML, like Gecko) Chrome/125.0 Safari/537.36 ParselOS-FSBO-Watcher/1.0"
