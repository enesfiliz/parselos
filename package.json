{
  "name": "parselos",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "engines": {
    "node": ">=20.0.0"
  },
  "scripts": {
    "dev": "node --max-old-space-size=8192 ./node_modules/next/dist/bin/next dev --turbo",
    "build": "prisma generate && next build",
    "build:hostinger": "prisma generate && prisma migrate deploy && next build",
    "postinstall": "prisma generate",
    "start": "node scripts/start-production.mjs",
    "pm2:start": "pm2 start ecosystem.config.js",
    "pm2:restart": "pm2 restart parselos",
    "pm2:stop": "pm2 stop parselos",
    "pm2:logs": "pm2 logs parselos",
    "lint": "eslint",
    "db:generate": "prisma generate",
    "db:push": "node --env-file=.env.local ./node_modules/prisma/build/index.js db push",
    "db:migrate": "prisma migrate dev",
    "db:deploy": "prisma migrate deploy",
    "db:studio": "prisma studio",
    "check:local": "node --env-file=.env.local scripts/check-local-env.mjs",
    "db:check": "node --env-file=.env.local scripts/check-db-connection.mjs",
    "db:seed": "node --env-file=.env.local --import tsx prisma/seed.ts",
    "db:deal-notes": "node --env-file=.env.local scripts/check-deal-note-table.mjs",
    "db:setup-voice-crm": "node --env-file=.env.local scripts/setup-voice-crm-table.mjs",
    "fsbo:hunt": "node --env-file=.env.local scripts/fsbo-opportunity-hunter.mjs",
    "fsbo:seed": "node --env-file=.env.local scripts/seed-fsbo-local.mjs",
    "fsbo:bot:install": "npm install --prefix scraper-bot",
    "fsbo:bot:once": "npm run scrape:once --prefix scraper-bot",
    "fsbo:bot:start": "npm start --prefix scraper-bot",
    "brand:extract": "node scripts/extract-brand-assets.mjs",
    "brand:svgs": "node scripts/extract-svg-from-transcript.mjs && node scripts/extract-partial-logo.mjs && node scripts/generate-svg-components.mjs",
    "brand:favicon": "node scripts/generate-favicon.mjs"
  },
  "dependencies": {
    "@ai-sdk/groq": "^3.0.39",
    "@ai-sdk/openai": "^3.0.68",
    "@ai-sdk/react": "^3.0.199",
    "@base-ui/react": "^1.5.0",
    "@clerk/nextjs": "^7.4.2",
    "@clerk/themes": "^2.4.57",
    "@dnd-kit/core": "^6.3.1",
    "@dnd-kit/sortable": "^10.0.0",
    "@dnd-kit/utilities": "^3.2.2",
    "@google/genai": "^2.8.0",
    "@google/generative-ai": "^0.24.1",
    "@hello-pangea/dnd": "^18.0.1",
    "@prisma/adapter-pg": "^7.8.0",
    "@prisma/client": "^7.8.0",
    "@react-pdf/renderer": "^4.5.1",
    "@supabase/ssr": "^0.10.3",
    "@supabase/supabase-js": "^2.106.2",
    "ai": "^6.0.197",
    "cheerio": "^1.2.0",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "framer-motion": "^12.40.0",
    "groq-sdk": "^1.2.1",
    "html2canvas": "^1.4.1",
    "jspdf": "^4.2.1",
    "leaflet": "^1.9.4",
    "lucide-react": "^1.17.0",
    "mapbox-gl": "^3.24.0",
    "next": "16.2.6",
    "next-themes": "^0.4.6",
    "openai": "^6.39.1",
    "pg": "^8.21.0",
    "react": "19.2.4",
    "react-dom": "19.2.4",
    "react-hook-form": "^7.77.0",
    "react-leaflet": "^5.0.0",
    "react-map-gl": "^8.1.1",
    "react-markdown": "^10.1.0",
    "react-to-print": "^3.3.0",
    "recharts": "^3.8.1",
    "shadcn": "^4.8.3",
    "sonner": "^2.0.7",
    "tailwind-merge": "^3.6.0",
    "tw-animate-css": "^1.4.0",
    "zod": "^4.4.3",
    "prisma": "^7.8.0"
  },
  "devDependencies": {
    "@tailwindcss/postcss": "^4",
    "@types/leaflet": "^1.9.21",
    "@types/mapbox-gl": "^3.4.1",
    "@types/node": "^20",
    "@types/pg": "^8.20.0",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "dotenv": "^16.6.1",
    "eslint": "^9",
    "eslint-config-next": "16.2.6",
    "sharp": "^0.34.5",
    "tailwindcss": "^4",
    "tsx": "^4.22.4",
    "typescript": "^5"
  },
  "prisma": {
    "seed": "node --env-file=.env.local --import tsx prisma/seed.ts"
  }
}
