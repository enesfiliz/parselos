# ── Lokal geliştirme (varsayılan) ─────────────────────────────────────────
PARSELOS_API_URL=http://localhost:3000/api/bot-sync
BOT_SECRET_KEY=parselos-local-dev-bot-secret-2026

# ── Hostinger (production'a taşıyınca) ────────────────────────────────────
# PARSELOS_API_URL=https://senin-domain.com/api/bot-sync
# BOT_SECRET_KEY=production-gizli-anahtar

# Zamanlama (node-cron ifadesi — varsayılan her gün 08:00)
CRON_SCHEDULE=0 8 * * *
CRON_TIMEZONE=Europe/Istanbul

# Tarama limitleri
MAX_LISTINGS_PER_TARGET=12
MIN_DELAY_MS=1800
MAX_DELAY_MS=4200

# Headless Chrome (mikro-sunucuda true kalmalı)
HEADLESS=true

# Hedef dosyası (JSON)
TARGETS_PATH=./targets.json

# Daemon başlarken hemen bir tarama çalıştır (opsiyonel)
# RUN_ON_START=1
